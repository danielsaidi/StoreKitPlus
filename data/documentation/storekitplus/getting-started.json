"symbol","required":true,"type":"topic","url":"\/documentation\/storekitplus\/storeservice\/restorepurchases()"},"doc://StoreKitPlus/documentation/StoreKitPlus/ProductRepresentable":{"role":"symbol","title":"ProductRepresentable","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProductRepresentable"}],"abstract":[{"type":"text","text":"This protocol can be implemented by types that are intended"},{"type":"text","text":" "},{"type":"text","text":"to represent an app’s StoreKit products."}],"identifier":"doc:\/\/StoreKitPlus\/documentation\/StoreKitPlus\/ProductRepresentable","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"ProductRepresentable"}],"url":"\/documentation\/storekitplus\/productrepresentable"},"doc://StoreKitPlus/documentation/StoreKitPlus/StoreService":{"role":"symbol","title":"StoreService","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"StoreService"}],"abstract":[{"type":"text","text":"This protocol can be implemented by any classes that can be"},{"type":"text","text":" "},{"type":"text","text":"used to manage store products."}],"identifier":"doc:\/\/StoreKitPlus\/documentation\/StoreKitPlus\/StoreService","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"StoreService"}],"url":"\/documentation\/storekitplus\/storeservice"},"doc://StoreKitPlus/documentation/StoreKitPlus/StoreContext":{"role":"symbol","title":"StoreContext","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"StoreContext"}],"abstract":[{"type":"text","text":"This class can be used to manage store information in a way"},{"type":"text","text":" "},{"type":"text","text":"that makes it observable."}],"identifier":"doc:\/\/StoreKitPlus\/documentation\/StoreKitPlus\/StoreContext","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"StoreContext"}],"url":"\/documentation\/storekitplus\/storecontext"},"doc://StoreKitPlus/documentation/StoreKitPlus/StoreService/getProducts()":{"role":"symbol","title":"getProducts()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getProducts"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"},{"kind":"text","text":" -> ["},{"kind":"typeIdentifier","text":"Product","preciseIdentifier":"s:8StoreKit7ProductV"},{"kind":"text","text":"]"}],"abstract":[{"type":"text","text":"Get all available products."}],"identifier":"doc:\/\/StoreKitPlus\/documentation\/StoreKitPlus\/StoreService\/getProducts()","kind":"symbol","required":true,"type":"topic","url":"\/documentation\/storekitplus\/storeservice\/getproducts()"},"doc://StoreKitPlus/documentation/StoreKitPlus/StoreService/syncStoreData()":{"role":"symbol","title":"syncStoreData()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"syncStoreData"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"},{"kind":"text","text":" "},{"kind":"keyword","text":"throws"}],"abstract":[{"type":"text","text":"Sync product and purchase information from the store to"},{"type":"text","text":" "},{"type":"text","text":"any implementation defined sync destination."}],"identifier":"doc:\/\/StoreKitPlus\/documentation\/StoreKitPlus\/StoreService\/syncStoreData()","kind":"symbol","required":true,"type":"topic","url":"\/documentation\/storekitplus\/storeservice\/syncstoredata()"},"doc://StoreKitPlus/documentation/StoreKitPlus":{"role":"collection","title":"StoreKitPlus","abstract":[{"type":"text","text":"StoreKitPlus adds extra functionality for working with StoreKit 2, like extensions, observable state, store services, etc."}],"identifier":"doc:\/\/StoreKitPlus\/documentation\/StoreKitPlus","kind":"symbol","type":"topic","url":"\/documentation\/storekitplus"}}}